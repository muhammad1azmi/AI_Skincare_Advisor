# .gcloudignore — optimized for Cloud Run backend deployment.
# APK builds now use GitHub Actions (not Cloud Build).

# Virtual environments
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/

# Version control
.git/

# IDE
.idea/
.vscode/
*.iml
.gemini/

# Flutter frontend (not needed for backend)
frontend/

# Node
node_modules/

# Cloud Build configs (not needed for Cloud Run source deploy)
cloudbuild*.yaml

# Misc
*.log
.DS_Store
Thumbs.db

# GitHub Actions
.github/
