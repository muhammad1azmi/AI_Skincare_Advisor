            "conversation": [
                {
                    "invocation_id": "inv-parallel-001",
                    "user_content": {
                        "parts": [
                            {
                                "text": "Is retinol safe for my skin and can I use it together with vitamin C?"
                            }
                        ],
                        "role": "user"
                    },
                    "final_response": {
                        "parts": [
                            {
                                "text": "Retinol is generally safe and effective for anti-aging and acne. However, when using retinol with vitamin C, it's best to apply them at different times — vitamin C in the morning and retinol at night — to avoid irritation."
                            }
                        ],
                        "role": "model"
                    },
